{
  "name": "cantonese-md",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/daimaruhk/Cantonese.md",
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm gen:api && pnpm gen:staticFiles",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "test": "vitest run",
    "gen:api": "tsx ./src/scripts/generate-api.ts",
    "gen:staticFiles": "tsx ./src/scripts/generate-staticFiles.ts",
    "gen:content": "tsx ./src/scripts/generate-content.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.2"
}
